#!/usr/bin/env bash
# claude-sandbox - run Claude Code inside a rootless Podman container.
#
#   claude-sandbox build      build (or rebuild) the image for your user
#   claude-sandbox doctor     run environment diagnostics in the container
#   claude-sandbox [args...]  run Claude Code in the current dir, args passed through
#
# The current directory must live under $CLAUDE_SANDBOX_ROOT (default ~/github).
# All of ~/github (so a session can span multiple repos) plus the repo's kube/
# dir are mounted, so nothing else in your home partition is reachable from the
# container.
set -euo pipefail

IMAGE="${CLAUDE_SANDBOX_IMAGE:-claude-sandbox:latest}"
MEMORY="${CLAUDE_SANDBOX_MEMORY:-8g}"
CPUS="${CLAUDE_SANDBOX_CPUS:-4}"
PIDS="${CLAUDE_SANDBOX_PIDS:-1024}"
GITHUB_ROOT="${CLAUDE_SANDBOX_ROOT:-$HOME/github}"
# auto mode (skip permission prompts). Set CLAUDE_SANDBOX_AUTO=0 for oversight
# mode - prompts apply and settings/settings.json tiers take effect.
AUTO="${CLAUDE_SANDBOX_AUTO:-1}"

# resolve symlinks so this works when invoked via a symlink in PATH
# (e.g. ~/.local/bin/claude-sandbox -> ~/tools/claude-setup/bin/claude-sandbox).
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
REPO_DIR="$(dirname "$SCRIPT_DIR")"

# --- build mode ---
if [ "${1:-}" = "build" ]; then
  exec podman build \
    --build-arg HOST_USER="$(id -un)" \
    --build-arg HOST_UID="$(id -u)" \
    --build-arg HOST_GID="$(id -g)" \
    --build-arg HOST_HOME="$HOME" \
    -t "$IMAGE" \
    -f "$REPO_DIR/Containerfile" \
    "$REPO_DIR"
fi

# doctor mode runs diagnostics instead of claude, reusing the run setup below
DOCTOR=0
if [ "${1:-}" = "doctor" ]; then DOCTOR=1; shift; fi

# --- run mode ---
WORKDIR="$PWD"
case "$WORKDIR" in
  "$GITHUB_ROOT" | "$GITHUB_ROOT"/*) ;;
  *)
    echo "claude-sandbox: run from within $GITHUB_ROOT (cwd: $WORKDIR)" >&2
    exit 1
    ;;
esac

mounts=()

# mount all of ~/github read-write so a session can span multiple repos; it still
# starts in your current dir (set with -w below).
mounts+=(-v "$GITHUB_ROOT:$GITHUB_ROOT:rw")

# kubeconfigs: the repo's gitignored kube/ dir becomes the container's ~/.kube,
# kept entirely separate from your host ~/.kube (your normal CLI is untouched).
# Drop kind/staging kubeconfigs in there; see kube/README.md.
if [ -d "$REPO_DIR/kube" ]; then
  mounts+=(-v "$REPO_DIR/kube:$HOME/.kube:rw")
fi

# share your real ~/.claude read-write so sessions, history, memory, auth,
# commands, hooks and plugins are one store with the host - resume works both
# ways and you don't log in twice.
mounts+=(-v "$HOME/.claude:$HOME/.claude:rw")

# mount your config inputs and the ~/.claude git repo read-only: the container has
# no reason to write these, so it can't clobber them or commit/push changes to your
# dotfiles repo - the host stays the control point for versioned config (you pull
# there to apply updates). Guards against accidents and casual tampering, NOT a
# determined rogue (which could copy files out and push from a writable spot). This
# sandbox is an accident + resource boundary, not an exfiltration one.
for ro in CLAUDE.md commands hooks .git; do
  [ -e "$HOME/.claude/$ro" ] && mounts+=(-v "$HOME/.claude/$ro:$HOME/.claude/$ro:ro")
done

# settings.json is also overridden with the curated read-only version: the host's
# enables the built-in bash sandbox and the claude-guard hook, both of which break
# or are redundant in the container. Its tiers apply in oversight mode (AUTO=0).
if [ -f "$REPO_DIR/settings/settings.json" ]; then
  mounts+=(-v "$REPO_DIR/settings/settings.json:$HOME/.claude/settings.json:ro")
fi

# choose what runs in the container: diagnostics or claude itself
if [ "$DOCTOR" = "1" ]; then
  DOCTOR_SCRIPT=$(cat <<'DOCTOR_EOF'
echo "== claude-sandbox doctor =="
echo
echo "-- identity / keep-id --"
echo "user $(id -un) uid=$(id -u) gid=$(id -g)  HOME=$HOME  PWD=$PWD"
t="$PWD/.cs-doctor.$$"
if touch "$t" 2>/dev/null; then
  o=$(stat -c '%u' "$t"); rm -f "$t"
  if [ "$o" = "$(id -u)" ]; then echo "PASS workdir writable, new files owned by uid $o"
  else echo "WARN workdir writable but files owned by uid $o (expected $(id -u))"; fi
else
  echo "FAIL workdir $PWD not writable"
fi
echo
echo "-- ~/.claude --"
s="$HOME/.claude/settings.json"
if [ -f "$s" ]; then
  if grep -q '"sandbox"' "$s"; then echo "WARN settings.json has a sandbox block (built-in bash sandbox may be ON)"
  else echo "PASS settings.json has no sandbox block (built-in bash sandbox off)"; fi
  if touch "$s" 2>/dev/null; then echo "WARN settings.json is writable (expected read-only)"
  else echo "PASS settings.json read-only"; fi
else
  echo "FAIL $s missing"
fi
for d in CLAUDE.md commands hooks .git; do
  p="$HOME/.claude/$d"; [ -e "$p" ] || { echo "warn $d not present"; continue; }
  if touch "$p/.cs-doctor" 2>/dev/null || { [ -f "$p" ] && touch "$p" 2>/dev/null; }; then
    rm -f "$p/.cs-doctor" 2>/dev/null; echo "WARN $d writable (expected read-only)"
  else echo "PASS $d read-only"; fi
done
p="$HOME/.claude/projects"
if [ -d "$p" ]; then
  if touch "$p/.cs-doctor" 2>/dev/null; then rm -f "$p/.cs-doctor"; echo "PASS projects writable (shared session store)"
  else echo "WARN projects not writable (resume sharing broken)"; fi
fi
echo
echo "-- toolchain --"
for c in go node pnpm yarn python3 make gh kubectl gcloud az podman docker claude; do
  if command -v "$c" >/dev/null 2>&1; then printf 'PASS %-8s %s\n' "$c" "$(command -v "$c")"
  else printf 'MISS %-8s\n' "$c"; fi
done
echo
echo "-- container runtime (docker/kind) --"
if podman info >/dev/null 2>&1; then echo "PASS nested podman ok"; else echo "WARN nested podman failed (docker/kind may not work)"; fi
if command -v docker >/dev/null 2>&1; then echo "docker -> $(readlink -f "$(command -v docker)")"; fi
echo
echo "-- resource caps (cgroup v2) --"
for f in memory.max pids.max cpu.max; do
  printf '%-11s %s\n' "$f" "$(cat /sys/fs/cgroup/$f 2>/dev/null || echo '?')"
done
echo
echo done
DOCTOR_EOF
)
  container_cmd=(bash -c "$DOCTOR_SCRIPT")
else
  container_cmd=(claude)
  if [ "$AUTO" = "1" ]; then container_cmd+=(--dangerously-skip-permissions); fi
  container_cmd+=("$@")
fi

exec podman run --rm -it \
  --userns=keep-id \
  --network=host \
  --device /dev/fuse \
  --memory="$MEMORY" --cpus="$CPUS" --pids-limit="$PIDS" \
  -w "$WORKDIR" \
  -e HOME="$HOME" \
  -e TERM="${TERM:-xterm-256color}" \
  -v claude-cache:"$HOME/.cache" \
  -v claude-go:"$HOME/go" \
  -v claude-pnpm:"$HOME/.local/share/pnpm" \
  -v claude-npm:"$HOME/.npm" \
  "${mounts[@]}" \
  "$IMAGE" \
  "${container_cmd[@]}"
